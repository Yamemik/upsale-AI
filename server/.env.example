# Скопируйте в .env в каталоге server/ (рядом с этим файлом):
#   copy .env.example .env   (Windows)
# Приоритет: переменные окружения > .env > значения по умолчанию в settings.py

# DB (база udsale-db — создать: см. scripts/create_udsale_db.sql или docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/udsale-db
DATABASE_URL_SYNC=postgresql://postgres:postgres@127.0.0.1:5432/udsale-db
# Локально на Windows при обрыве соединения (10054) включите:
DATABASE_SSL_DISABLE=true
DATABASE_CONNECT_TIMEOUT=30

# auth
AUTH_PROVIDER=local

# superuser
SUPERUSER_EMAIL=kuancarlos@mail.ru
SUPERUSER_PASSWORD=admin123

# JWT настройки
JWT_SECRET_KEY=qjdi!kjshu
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt
BC_SECRET_KEY=dgadfgeefa
